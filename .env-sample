# ============================================================
# E-RECYCLO — Local Environment Configuration Template (.env-sample)
# Copy this file to a new file named '.env' and fill in your actual values.
# ============================================================

# Active environment: 'development' or 'production'
ENVIRONMENT=development

# ========================================
# DJANGO CORE SETTINGS
# ========================================

# Generate a secure key for production (e.g. from https://djecrety.ir/)
SECRET_KEY=your_django_secret_key_here

# Enable debug mode for local testing
DEBUG=True

# Allowed host names
ALLOWED_HOSTS=localhost,127.0.0.1

# ========================================
# DATABASE SETTINGS (PostgreSQL Local)
# ========================================

DB_NAME=erecyclo_db
DB_USER=your_postgres_username
DB_PASSWORD=your_postgres_password
DB_HOST=localhost
DB_PORT=5432

# Note: Production settings in production.py parse DATABASE_URL (for Supabase connection)
# DATABASE_URL=postgresql://postgres:password@db.supabase.co:5432/postgres

# ========================================
# EMAIL SETTINGS (Gmail SMTP - OTP Delivery)
# ========================================

EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_USE_SSL=False

# Replace with your Gmail account and a 16-character Gmail App Password:
EMAIL_HOST_USER=your_email@gmail.com
EMAIL_HOST_PASSWORD=your_16_character_gmail_app_password

DEFAULT_FROM_EMAIL="E-RECYCLO <noreply@erecyclo.in>"

# OTP expiry window in minutes
OTP_EXPIRY_MINUTES=10

# ========================================
# RAZORPAY API INTEGRATION
# ========================================

# Use 'rzp_test_...' keys for local development
RAZORPAY_KEY_ID=your_razorpay_key_id
RAZORPAY_KEY_SECRET=your_razorpay_key_secret

# Custom webhook signature verification token
RAZORPAY_WEBHOOK_SECRET=your_razorpay_webhook_secret_here

# Your Razorpay merchant account number
RAZORPAY_ACCOUNT_NUMBER=your_razorpay_account_number
